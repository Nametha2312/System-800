# =============================================================================
# System-800 — Environment Configuration Reference
# =============================================================================
# Copy backend/.env.example to backend/.env and fill in every value.
#
# GENERATING STRONG SECRETS (run these in a terminal):
#   JWT_SECRET:       openssl rand -hex 64
#   JWT_REFRESH_SECRET: openssl rand -hex 64
#   ENCRYPTION_KEY:   openssl rand -hex 16   (generates 32 hex chars = 16 bytes)
#
# REQUIRED VARIABLES (server will not start without these):
#   DATABASE_URL, JWT_SECRET, JWT_REFRESH_SECRET, ENCRYPTION_KEY
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
NODE_ENV=production          # development | test | production
PORT=4000
HOST=0.0.0.0
API_VERSION=v1

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
# Local: postgresql://user:password@localhost:5432/system800
# Neon:  postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/system800
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20
DATABASE_IDLE_TIMEOUT=30000
DATABASE_CONNECTION_TIMEOUT=10000

# ---------------------------------------------------------------------------
# Redis (optional — set SKIP_REDIS_CONNECT=true to use in-process poller)
# ---------------------------------------------------------------------------
SKIP_REDIS_CONNECT=false
REDIS_URL=redis://localhost:6379
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY=1000

# ---------------------------------------------------------------------------
# Authentication — CHANGE ALL VALUES IN PRODUCTION
# Generate: openssl rand -hex 64
# ---------------------------------------------------------------------------
JWT_SECRET=REPLACE_ME_WITH_CRYPTOGRAPHICALLY_RANDOM_64_CHAR_HEX_STRING
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=REPLACE_ME_WITH_DIFFERENT_64_CHAR_HEX_STRING
JWT_REFRESH_EXPIRES_IN=7d

# ---------------------------------------------------------------------------
# Encryption — EXACTLY 32 characters
# Generate: python3 -c "import secrets; print(secrets.token_hex(16))"
# ---------------------------------------------------------------------------
ENCRYPTION_KEY=REPLACE_ME_EXACTLY_32_CHARACTERS

# ---------------------------------------------------------------------------
# Rate Limiting
# ---------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000       # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# ---------------------------------------------------------------------------
# Monitoring
# ---------------------------------------------------------------------------
DEFAULT_POLLING_INTERVAL_MS=60000  # 1 minute
MIN_POLLING_INTERVAL_MS=10000
MAX_POLLING_INTERVAL_MS=300000
COOLDOWN_PERIOD_MS=60000

# ---------------------------------------------------------------------------
# Circuit Breaker
# ---------------------------------------------------------------------------
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_RESET_TIMEOUT_MS=60000
CIRCUIT_BREAKER_HALF_OPEN_MAX_REQUESTS=3

# ---------------------------------------------------------------------------
# Retry
# ---------------------------------------------------------------------------
MAX_RETRY_ATTEMPTS=3
RETRY_BASE_DELAY_MS=1000
RETRY_MAX_DELAY_MS=30000

# ---------------------------------------------------------------------------
# Queue (BullMQ — only used when SKIP_REDIS_CONNECT=false)
# ---------------------------------------------------------------------------
QUEUE_CONCURRENCY=5
QUEUE_MAX_JOBS_PER_WORKER=100
DEAD_LETTER_MAX_AGE_DAYS=7

# ---------------------------------------------------------------------------
# Browser Automation (Puppeteer)
# ---------------------------------------------------------------------------
PUPPETEER_HEADLESS=true
PUPPETEER_TIMEOUT_MS=30000
PUPPETEER_NAVIGATION_TIMEOUT_MS=60000
# Optional: path to a real Chrome/Chromium binary. When set, Puppeteer uses this
# instead of its bundled Chromium — recommended in production for better stealth.
# Linux example: PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
# Windows example: PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
# PUPPETEER_EXECUTABLE_PATH=

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=info              # debug | info | warn | error
LOG_PRETTY_PRINT=false      # false in production (JSON), true in development

# ---------------------------------------------------------------------------
# CORS (comma-separated list of allowed origins)
# ---------------------------------------------------------------------------
CORS_ORIGIN=https://yourdomain.com
CORS_CREDENTIALS=true

# ---------------------------------------------------------------------------
# Notifications (all optional)
# ---------------------------------------------------------------------------
NOTIFY_EMAIL_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=user@example.com
SMTP_PASS=your_smtp_password
NOTIFY_EMAIL_FROM=alerts@yourdomain.com
NOTIFY_EMAIL_TO=admin@yourdomain.com

NOTIFY_TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

NOTIFY_DISCORD_ENABLED=false
DISCORD_WEBHOOK_URL=

# ---------------------------------------------------------------------------
# ScraperAPI (required for Walmart, Target, Pokémon Center monitoring)
# ---------------------------------------------------------------------------
# Sign up free at https://www.scraperapi.com — 1 000 free credits/month.
# Without this key those three retailers will throw a configuration error
# instead of attempting a direct request that would be blocked anyway.
SCRAPER_API_KEY=32fc39957a8953fde1e07e9376ebbfdf

# ---------------------------------------------------------------------------
# Proxy Pool (optional — for Puppeteer anti-bot evasion)
# ---------------------------------------------------------------------------
PROXY_ENABLED=false
# Comma-separated: http://user:pass@ip:port,http://user:pass@ip2:port2
PROXY_POOL=
PROXY_ROTATION_MODE=soft    # soft | aggressive
PROXY_MIN_ROTATION_INTERVAL_MS=30000
PROXY_QUARANTINE_DURATION_MS=600000
PROXY_MAX_ROTATIONS_PER_TASK=5

