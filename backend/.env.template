# Application
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
API_VERSION=v1

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/system800
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_IDLE_TIMEOUT=30000
DATABASE_CONNECTION_TIMEOUT=10000

# Redis
REDIS_URL=redis://localhost:6379
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY=1000
# Set to true in development when Redis is not running (uses in-process poller instead)
SKIP_REDIS_CONNECT=false

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your-refresh-token-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Encryption
ENCRYPTION_KEY=your-32-character-encryption-key!
ENCRYPTION_IV_LENGTH=16

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Monitoring Configuration
DEFAULT_POLLING_INTERVAL_MS=30000
MIN_POLLING_INTERVAL_MS=10000
MAX_POLLING_INTERVAL_MS=300000
COOLDOWN_PERIOD_MS=60000

# Circuit Breaker
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_RESET_TIMEOUT_MS=30000
CIRCUIT_BREAKER_HALF_OPEN_MAX_REQUESTS=3

# Retry Configuration
MAX_RETRY_ATTEMPTS=3
RETRY_BASE_DELAY_MS=1000
RETRY_MAX_DELAY_MS=30000

# Queue Configuration
QUEUE_CONCURRENCY=5
QUEUE_MAX_JOBS_PER_WORKER=100
DEAD_LETTER_MAX_AGE_DAYS=7

# Puppeteer / Browser
PUPPETEER_HEADLESS=true
PUPPETEER_TIMEOUT_MS=30000
PUPPETEER_NAVIGATION_TIMEOUT_MS=60000

# Alerting (legacy webhook — still works in parallel with channels below)
ALERT_WEBHOOK_URL=

