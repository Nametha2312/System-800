# ── Proxy Management ─────────────────────────────────────────────────────────
# Set PROXY_ENABLED=true and supply a comma-separated list of proxy URLs.
# Supported format: http://username:password@host:port
# Leave PROXY_POOL blank to use direct connection even when enabled.
PROXY_ENABLED=false
PROXY_POOL=

# soft   = tolerate 1 captcha and 2 timeouts before rotating
# aggressive = rotate on first captcha or timeout
PROXY_ROTATION_MODE=soft

# Minimum milliseconds between rotations for the same task (anti-thrashing)
PROXY_MIN_ROTATION_INTERVAL_MS=30000

# How long (ms) a proxy stays quarantined after a hard block/403
PROXY_QUARANTINE_DURATION_MS=600000

# Max times the system will rotate proxy within a single task session
# before falling back to direct connection
PROXY_MAX_ROTATIONS_PER_TASK=5

# Logging
LOG_LEVEL=info
LOG_PRETTY_PRINT=true

# CORS
CORS_ORIGIN=http://localhost:3001
CORS_CREDENTIALS=true

# Session
SESSION_SECRET=TalhaSecret12345

# Health Check
HEALTH_CHECK_INTERVAL_MS=30000
