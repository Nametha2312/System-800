# Test Environment Configuration
NODE_ENV=test
PORT=3001
HOST=localhost
API_VERSION=v1

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/system800_test
DATABASE_POOL_MIN=1
DATABASE_POOL_MAX=5
DATABASE_IDLE_TIMEOUT=30000
DATABASE_CONNECTION_TIMEOUT=10000

# Redis
REDIS_URL=redis://localhost:6379
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY=1000

# JWT Authentication
JWT_SECRET=test-jwt-secret-for-testing-only
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=test-refresh-secret-for-testing
JWT_REFRESH_EXPIRES_IN=7d

# Encryption (32 characters exactly)
ENCRYPTION_KEY=test-encryption-key-32-chars!!
ENCRYPTION_IV_LENGTH=16

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# Monitoring Configuration
DEFAULT_POLLING_INTERVAL_MS=30000
MIN_POLLING_INTERVAL_MS=10000
MAX_POLLING_INTERVAL_MS=300000
COOLDOWN_PERIOD_MS=60000

# Circuit Breaker
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_RESET_TIMEOUT_MS=30000
CIRCUIT_BREAKER_HALF_OPEN_MAX_REQUESTS=3

# Retry Configuration
MAX_RETRY_ATTEMPTS=3
RETRY_BASE_DELAY_MS=100
RETRY_MAX_DELAY_MS=1000

# Queue Configuration
QUEUE_CONCURRENCY=1
QUEUE_MAX_JOBS_PER_WORKER=10
DEAD_LETTER_MAX_AGE_DAYS=1

# Puppeteer / Browser
PUPPETEER_HEADLESS=true
PUPPETEER_TIMEOUT_MS=5000
PUPPETEER_NAVIGATION_TIMEOUT_MS=10000

# Logging
LOG_LEVEL=error
LOG_PRETTY_PRINT=false

# CORS
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=true
